{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "Node",
		"jsx": "react-jsx",

		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": false,

		"isolatedModules": true,
		"verbatimModuleSyntax": true,

		"strict": true,
		"skipLibCheck": true,
		"exactOptionalPropertyTypes": true,
		"baseUrl": ".",
		"paths": {
			"@token-quest/ui/*": ["./src/*"]
		}
	},
	"include": ["."],
	"exclude": ["node_modules", "dist"]
}
