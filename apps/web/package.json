{
	"name": "web",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "vite build",
		"preview": "vite preview",
		"test": "vitest run",
		"format": "biome format",
		"lint": "biome check --write .",
		"deploy": "pnpm run build && wrangler deploy",
		"cf-typegen": "wrangler types -c wrangler.jsonc -c ../api/wrangler.json",
		"db:generate:auth": "pnpm dlx auth@latest generate --config=./src/lib/services/runtime/auth/auth-defaults.ts --output=./src/lib/services/runtime/db/schema/auth.ts --yes",
		"db:generate": "pnpm run db:generate:auth && pnpm drizzle-kit generate",
		"db:migrate": "wrangler d1 migrations apply DB"
	},
	"dependencies": {
		"@better-auth/api-key": "^1.6.11",
		"@better-auth/drizzle-adapter": "^1.6.11",
		"@cloudflare/vite-plugin": "^1.37.0",
		"@fontsource-variable/space-grotesk": "^5.2.10",
		"@fontsource/space-mono": "^5.2.9",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/react-devtools": "latest",
		"@tanstack/react-router": "latest",
		"@tanstack/react-router-devtools": "latest",
		"@tanstack/react-router-ssr-query": "latest",
		"@tanstack/react-start": "latest",
		"@tanstack/router-plugin": "^1.132.0",
		"@token-quest/core": "workspace:^",
		"@token-quest/ui": "workspace:^",
		"better-auth": "^1.6.11",
		"drizzle-orm": "^0.45.2",
		"effect": "4.0.0-beta.65",
		"lucide-react": "^0.545.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"recharts": "2.15.4",
		"tailwindcss": "^4.1.18"
	},
	"devDependencies": {
		"@tailwindcss/typography": "^0.5.16",
		"@tanstack/devtools-vite": "latest",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.0",
		"@token-quest/biome-config": "workspace:^",
		"@types/node": "^22.10.2",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"@vitejs/plugin-react": "^6.0.1",
		"drizzle-kit": "^0.31.10",
		"jsdom": "^28.1.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.0",
		"vitest": "^4.1.5",
		"wrangler": "^4.91.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"lightningcss"
		]
	}
}
